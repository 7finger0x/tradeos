# Copy to `.env.local` at repo root AND `apps/web/.env.local` (Next.js middleware reads app-local env).
#
# Local Supabase (default): run `npx supabase start` then use these keys.
# Remote Supabase: Dashboard → Project Settings → API → Project URL + anon/public key.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Server-only (never expose to client; optional for local dev, required for admin/server tasks)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Market data (optional; defaults to mock)
# MARKET_DATA_PROVIDER=mock

# AI providers (Phase 5+; required for briefing/coach features)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
